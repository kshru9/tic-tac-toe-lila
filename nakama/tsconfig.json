{
  "compilerOptions": {
    "target": "ES5",
    "module": "none",
    "lib": ["ES5"],
    "outFile": "./build/index.js",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "noEmitOnError": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "files": [
    "src/nakama.d.ts",
    "src/gameRules.ts",
    "src/ticTacToeMatch.ts",
    "src/rpc.ts",
    "src/index.ts"
  ],
  "exclude": ["node_modules", "build"]
}
