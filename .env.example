# LILA Tic-Tac-Toe - Environment Variables
# Copy this file to .env and update values for your environment

# ============================================
# Nakama Configuration
# ============================================

# Nakama server hostname or IP address
# For local development: Use 'localhost' or your machine's IP
# For production: Use your deployed Nakama server domain
VITE_NAKAMA_HOST=localhost

# Nakama HTTP API port (default: 7350)
VITE_NAKAMA_PORT=7350

# Server authentication key
# WARNING: Use a secure key in production, not 'defaultkey'
VITE_NAKAMA_SERVER_KEY=defaultkey

# Whether to use SSL for connections
# For local development: false
# For production: true (requires SSL certificates)
VITE_NAKAMA_USE_SSL=false

# WebSocket port (usually same as HTTP port)
VITE_NAKAMA_WEBSOCKET_PORT=7350

# ============================================
# Frontend Configuration
# ============================================

# Application title shown in the UI
VITE_APP_TITLE=LILA Tic-Tac-Toe

# ============================================
# Environment Notes
# ============================================

# Local Development:
# - Set VITE_NAKAMA_HOST to 'localhost' or your local IP
# - Set VITE_NAKAMA_USE_SSL to false
# - VITE_NAKAMA_SERVER_KEY can remain 'defaultkey'

# Production Deployment:
# - Set VITE_NAKAMA_HOST to your deployed server domain
# - Set VITE_NAKAMA_USE_SSL to true
# - Generate a secure VITE_NAKAMA_SERVER_KEY
# - Update VITE_APP_TITLE if desired
# - Rebuild frontend after changing these values