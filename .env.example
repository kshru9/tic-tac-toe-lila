# LILA Tic-Tac-Toe - Environment Variables
# Copy this file to .env and update values for your environment

# ============================================
# Nakama Configuration
# ============================================

# Nakama server hostname or IP address
# REQUIRED: This value must be set for both local development and production
# For local development: Use '[private-host-redacted]' or your machine's IP
# For production: Use your deployed Nakama server domain (e.g., 'nakama.example.com')
# WARNING: The frontend no longer has a fallback value - this must be explicitly set
VITE_NAKAMA_HOST=[private-host-redacted]

# Nakama HTTP API port (default: 7350)
VITE_NAKAMA_PORT=7350

# Server authentication key
# WARNING: Use a secure key in production, not 'defaultkey'
VITE_NAKAMA_SERVER_KEY=defaultkey

# Whether to use SSL for connections
# For local development: false
# For production: true (requires SSL certificates and reverse proxy)
VITE_NAKAMA_USE_SSL=false

# WebSocket port (usually same as HTTP port)
VITE_NAKAMA_WEBSOCKET_PORT=7350

# ============================================
# Frontend Configuration
# ============================================

# Application title shown in the UI
VITE_APP_TITLE=LILA Tic-Tac-Toe

# ============================================
# Environment Notes
# ============================================

# Local Development:
# - Set VITE_NAKAMA_HOST to '[private-host-redacted]' or your local IP
# - Set VITE_NAKAMA_USE_SSL to false
# - VITE_NAKAMA_SERVER_KEY can remain 'defaultkey'
# - The frontend will fail to connect if VITE_NAKAMA_HOST is not set

# Production Deployment:
# - Set VITE_NAKAMA_HOST to your deployed server domain (e.g., 'nakama.example.com')
# - Set VITE_NAKAMA_USE_SSL to true (requires TLS termination/reverse proxy)
# - Generate a secure VITE_NAKAMA_SERVER_KEY (not 'defaultkey')
# - Configure CORS on Nakama to allow your frontend domain
# - Update VITE_APP_TITLE if desired
# - Rebuild frontend after changing these values

# ============================================
# Railway + GitHub Pages Deployment
# ============================================

# For Railway backend deployment:
# 1. Railway provides automatic TLS certificates and public networking
# 2. Set DATABASE_URL to Railway PostgreSQL service reference
# 3. Set NAKAMA_RUNTIME_PATH=/nakama/data/modules
# 4. Generate secure NAKAMA_SERVER_KEY (not 'defaultkey')
# 5. Set NAKAMA_CORS_ORIGIN to your GitHub Pages URL

# For GitHub Pages frontend deployment:
# 1. Set VITE_NAKAMA_HOST to your Railway public domain
# 2. Set VITE_NAKAMA_USE_SSL=true
# 3. Use same secure server key as Railway
# 4. Set VITE_BASE_PATH to repository name for project Pages URLs
# 5. GitHub Actions workflow handles build and deployment

# Railway automatically provides:
# - HTTPS/WSS connections with TLS certificates
# - Public domain with automatic SSL
# - PostgreSQL database with private networking
# - Container build and deployment